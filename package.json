{
  "name": "juntti-platform",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*",
    "admin"
  ],
  "scripts": {
    "dev:juntti": "npm run dev --workspace=apps/juntti",
    "dev:tietovisa": "npm run dev --workspace=apps/tietovisa",
    "dev:admin": "npm run dev --workspace=admin",
    "build": "npm run build --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
