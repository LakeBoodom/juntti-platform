# Tietoniekka — local env example
# Copy to .env.local and fill from Supabase + Vercel dashboards (sama Supabase
# kuin Juntilla; ks. juurihakemiston CLAUDE.md "Environment variables").

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

NEXT_PUBLIC_SITE_NAME=Tietoniekka
